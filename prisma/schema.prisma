// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum AuthType {
  EMAIL
  GOOGLE
  AUTH0
}

model User {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name     String
  email    String
  verified Boolean  @default(false)
  authType AuthType @default(EMAIL)
  
  // Auth0 specific fields
  auth0Id      String?  @unique // Auth0 user ID (sub claim from JWT)
  userMetadata Json?    // Auth0 user_metadata
  appMetadata  Json?    // Auth0 app_metadata
  picture      String?  // Profile picture URL
  nickname     String?  // User nickname
  emailVerified Boolean @default(false) // Email verification status

  ship Spaceship?
}

model Spaceship {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  name      String
  fleet     String
  captain   User   @relation(fields: [captainId], references: [id])
  captainId String @unique
}
